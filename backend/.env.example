# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kavabanga
DB_USER=postgres
DB_PASSWORD=your_db_password

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_jwt_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# Option A: path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Option B: inline JSON (base64-encoded) — use one or the other
# FIREBASE_SERVICE_ACCOUNT_BASE64=<base64-encoded service account JSON>

# Firebase Storage bucket name (without gs://)
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# ─── Test database (used by Jest) ─────────────────────────────────────────────
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=kavabanga_test
TEST_DB_USER=postgres
TEST_DB_PASSWORD=your_db_password
